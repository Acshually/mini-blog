<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gradient-to-br from-slate-900 to-black w-full min-h-screen text-slate-100 flex items-center justify-center selection:bg-emerald-500/30">
    <div class="bg-slate-800/80 backdrop-blur-md p-8 rounded-3xl shadow-2xl shadow-emerald-900/10 w-full max-w-md border border-slate-700/50">
        <h2 class="text-3xl font-bold text-center mb-6 text-emerald-400">Create Account</h2>
        <form action="/register" method="POST" class="flex flex-col gap-4">
            <input type="text" class="w-full p-3 rounded-lg bg-slate-700 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 placeholder:text-slate-400" placeholder="Enter your name" name="name" required>
            <input type="text" class="w-full p-3 rounded-lg bg-slate-700 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 placeholder:text-slate-400" placeholder="Enter your username" name="username" required>
            <input type="email" class="w-full p-3 rounded-lg bg-slate-700 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 placeholder:text-slate-400" placeholder="Enter your email" name="email" required>
            <input type="password" class="w-full p-3 rounded-lg bg-slate-700 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 placeholder:text-slate-400" placeholder="Enter your password" name="password" required>
            <input type="number" class="w-full p-3 rounded-lg bg-slate-700 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 placeholder:text-slate-400" placeholder="Enter your age" name="age" required>
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-4 py-3 rounded-lg transition-colors duration-200 mt-2">Create account</button>
        </form>
        <p class="text-center mt-6 text-slate-400">
            Already have an account? 
            <a href="/login" class="text-emerald-400 hover:text-emerald-300 font-semibold hover:underline">Login here</a>
        </p>
    </div>
</body>
</html>