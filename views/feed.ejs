<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Feed</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="w-full min-h-screen bg-gradient-to-br from-slate-950 to-slate-900 text-slate-100 selection:bg-emerald-500/30">
    <!-- Navbar -->
    <nav class="w-full flex justify-between items-center p-5 bg-slate-900/80 backdrop-blur-md border-b border-slate-800/50 sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <h1 class="text-2xl font-bold text-emerald-400">Global Feed</h1>
        </div>
        <div class="flex items-center gap-4">
            <a href="/profile" class="text-slate-300 hover:text-white font-semibold transition-colors">My Profile</a>
            <a href="/logout" class="bg-red-500/10 hover:bg-red-500 hover:text-white text-red-500 border border-red-500/50 font-semibold py-2 px-6 rounded-lg transition-colors">Logout</a>
        </div>
    </nav>

    <main class="max-w-2xl mx-auto mt-8 p-5">
        <div class="posts space-y-6">
            
            <% if (posts.length === 0) { %>
                <div class="text-center text-slate-500 py-10 bg-slate-900 rounded-xl border border-slate-800">
                    No posts yet in the global feed. Be the first to post!
                </div>
            <% } %>

            <div class="postcoaintainer space-y-6">
                <% posts.forEach(function(post) { %>
                    <div class="post bg-slate-900/60 backdrop-blur-sm p-6 rounded-2xl border border-slate-800/60 shadow-lg hover:shadow-xl hover:bg-slate-900/80 transition-all duration-300">
                        <div class="flex items-center gap-3 mb-4 border-b border-slate-800/50 pb-4">
                            <% if(post.user && post.user.profilepic) { %>
                                <img src="/images/uploads/<%= post.user.profilepic %>" alt="Profile" class="w-10 h-10 rounded-full object-cover border border-slate-700">
                            <% } else { %>
                                <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-500 font-bold border border-slate-700">?</div>
                            <% } %>
                            
                            <div>
                                <h4 class="font-bold text-emerald-400"><%= post.user ? post.user.username : 'Unknown User' %></h4>
                                <small class="text-xs text-slate-500"><%= new Date(post.date).toLocaleString() %></small>
                            </div>
                        </div>
                        
                        <p class="text-slate-200 mb-4 whitespace-pre-wrap text-lg"><%= post.content %></p>
                        
                        <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-800">
                            <div class="flex items-center gap-4 text-sm">
                                <a href="/like/<%= post._id %>" class="flex items-center gap-2 group <%= post.likes.indexOf(user._id)!==-1 ? 'text-emerald-500' : 'text-slate-400 hover:text-emerald-400' %> transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 <%= post.likes.indexOf(user._id)!==-1 ? 'fill-current' : 'fill-none' %> group-hover:scale-110 transition-transform" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                    <span class="text-base"><%= post.likes.length %></span>
                                </a>
                            </div>
                            
                            <% if(post.user && post.user._id.toString() === user._id.toString()) { %>
                            <a href="/edit/<%=post._id %>" class="text-sm text-slate-400 hover:text-green-400 flex items-center gap-1 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Edit
                            </a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </main>
</body>
</html>
