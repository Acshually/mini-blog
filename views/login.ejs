<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-900 w-full min-h-screen text-white font-sans flex items-center justify-center">
    <div class="bg-zinc-800 p-8 rounded-2xl shadow-xl w-full max-w-md border border-zinc-700">
        <h2 class="text-3xl font-bold text-center mb-6 text-blue-400">Welcome Back</h2>
        <form action="/login" method="POST" class="flex flex-col gap-4">
            <input type="email" class="w-full p-3 rounded-lg bg-zinc-700 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder:text-zinc-400" placeholder="Enter your email" name="email" required>
            <input type="password" class="w-full p-3 rounded-lg bg-zinc-700 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder:text-zinc-400" placeholder="Enter your password" name="password" required>
            
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-3 rounded-lg transition-colors duration-200 mt-2">Login</button>
        </form>
        <p class="text-center mt-6 text-zinc-400">
            Don't have an account? 
            <a href="/" class="text-blue-400 hover:text-blue-300 font-semibold hover:underline">Create one</a>
        </p>
    </div>
</body>
</html>