<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="w-full min-h-screen bg-zinc-950 text-white font-sans">
    <!-- Navbar -->
    <nav class="w-full flex justify-between items-center p-5 bg-zinc-900 border-b border-zinc-800">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 relative group cursor-pointer" onclick="window.location.href='/profile/upload'">
                <img src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture" class="w-full h-full object-cover rounded-full border-2 border-blue-500 group-hover:opacity-50 transition-opacity">
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity text-xs font-bold text-white bg-black/50 rounded-full">
                    Edit
                </div>
            </div>
            <h1 class="text-2xl font-semibold">Welcome, <span class="text-blue-400"><%= user.name %></span>!</h1>
        </div>
        <div class="flex items-center gap-4">
            <a href="/feed" class="text-zinc-300 hover:text-white font-semibold transition-colors">Global Feed</a>
            <a href="/logout" class="bg-red-500/10 hover:bg-red-500 hover:text-white text-red-500 border border-red-500/50 font-semibold py-2 px-6 rounded-lg transition-colors">Logout</a>
        </div>
    </nav>

    <main class="max-w-3xl mx-auto mt-8 p-5">
        <!-- Create Post Section -->
        <div class="bg-zinc-900 p-6 rounded-xl border border-zinc-800 shadow-lg mb-8">
            <h2 class="text-xl font-medium mb-4">Create a new post</h2>
            <form action="/post" method="POST" class="flex flex-col gap-4">
                <textarea name="content" class="w-full bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent rounded-lg resize-none p-4 min-h-[100px]" placeholder="What's on your mind?"></textarea>
                <div class="flex justify-end">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg transition-colors">Post</button>
                </div>
            </form>
        </div>

        <!-- Posts Feed -->
        <div class="posts space-y-6">
            <h3 class="text-xl font-medium mb-4">Recent Posts</h3>
            
            <% if (user.posts.length === 0) { %>
                <div class="text-center text-zinc-500 py-10 bg-zinc-900 rounded-xl border border-zinc-800">
                    No posts yet. Create one above!
                </div>
            <% } %>

            <div class="postcoaintainer space-y-4">
                <% user.posts.reverse().forEach(function(post) { %>
                    <div class="post bg-zinc-900 p-6 rounded-xl border border-zinc-800 shadow-md transition-transform hover:-translate-y-1">
                        <div class="flex justify-between items-start mb-3">
                            <h4 class="font-bold text-blue-400"><%= user.username %></h4>
                        </div>
                        <p class="text-zinc-200 mb-4 whitespace-pre-wrap"><%= post.content %></p>
                        
                        <div class="flex items-center justify-between mt-4 pt-4 border-t border-zinc-800">
                            <div class="flex items-center gap-4 text-sm">
                                <a href="/like/<%= post._id %>" class="flex items-center gap-2 group <%= post.likes.indexOf(user._id)!==-1 ? 'text-blue-500' : 'text-zinc-400 hover:text-blue-400' %> transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 <%= post.likes.indexOf(user._id)!==-1 ? 'fill-current' : 'fill-none' %> group-hover:scale-110 transition-transform" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                    <span><%= post.likes.length %> <%= post.likes.length === 1 ? 'like' : 'likes' %></span>
                                </a>
                            </div>
                            <a href="/edit/<%=post._id %>" class="text-sm text-zinc-400 hover:text-green-400 flex items-center gap-1 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Edit
                            </a>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </main>
</body>
</html>